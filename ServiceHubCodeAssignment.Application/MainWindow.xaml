<Window x:Class="ServiceHubCodeAssignment.Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ServiceHubCodeAssignment"
        mc:Ignorable="d"
        Title="Service Hub - Code Assignment"
        Height="450"
        Width="800"
        Icon="favicon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Services"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="10,10,10,5"/>

        <DataGrid Grid.Row="1"
                  x:Name="ServicesDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5"
                  Margin="10,0,10,5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="40"/>
                <DataGridTextColumn Header="Name"        Binding="{Binding Name}"         Width="180"/>
                <DataGridTextColumn Header="Category"    Binding="{Binding Category}"     Width="100"/>
                <DataGridTextColumn Header="Status"      Binding="{Binding Status}"       Width="80"/>
                <DataGridTextColumn Header="Owner"       Binding="{Binding Owner}"        Width="130"/>
                <DataGridTextColumn Header="Last Updated" Binding="{Binding LastUpdated}" Width="110"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}"  Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Label Grid.Row="2"
               HorizontalAlignment="Right"
               Margin="0,0,10,5">
            Austin Oberholtzer
        </Label>
    </Grid>
</Window>
